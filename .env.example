# ── Java code execution ──────────────────────────────────────────────
# Welke backend voert de Java-code uit? judge0 | piston | wandbox
#   judge0  = managed API, PLUG & PLAY: geen server, enkel een key (zie README)
#   piston  = zelf-gehoste Piston (snel + onbeperkt, maar vraagt een VPS)
#   wandbox = gratis publieke dienst, GEEN setup nodig (ideaal om te testen)
EXEC_BACKEND=judge0

# ── Judge0 (plug & play, aanrader voor Vercel) ───────────────────────
# Zonder key gebruikt hij de gratis publieke instantie ce.judge0.com
# (werkt, maar gedeeld → kan traag/gelimiteerd zijn). Voor betrouwbaarheid:
# maak een gratis RapidAPI-account, abonneer op "Judge0 CE", en zet:
#   JUDGE0_URL=https://judge0-ce.p.rapidapi.com
#   JUDGE0_KEY=<jouw X-RapidAPI-Key>
JUDGE0_URL=https://ce.judge0.com
JUDGE0_KEY=
# Taal-id: 62 = OpenJDK 13 (overal aanwezig). 91 = JDK 17 op nieuwere instanties.
JUDGE0_LANGUAGE_ID=62

# Rate-limit: max RUN_MAX_PER_WINDOW uitvoeringen per RUN_COOLDOWN_MS per
# gebruiker/sessie (beschermt je Judge0-quota). Standaard 3 per 20s. Werkt het
# best met Upstash (zie onder); zonder Upstash is het per server-instance.
RUN_COOLDOWN_MS=20000
RUN_MAX_PER_WINDOW=3

# Piston (zelf-gehost). Let op: self-host pad is /api/v2/execute (GEEN /piston/).
# Op Vercel: wijs dit naar je Piston-VPS, bv. https://piston.jouwsite.be/api/v2/execute
PISTON_URL=http://localhost:2000/api/v2/execute
PISTON_JAVA_VERSION=*
# Gedeeld geheim zodat enkel deze app je (publieke) Piston-VPS mag aanspreken.
# Leeg laten als Piston enkel op localhost draait (zelfde server). Zie deploy/.
PISTON_AUTH=

# Wandbox (alleen relevant als EXEC_BACKEND=wandbox)
WANDBOX_COMPILER=openjdk-jdk-21+35

# ── Upstash Redis (leaderboard / sessies / notificaties) — OPTIONEEL ──
# Zonder deze waarden draait de app lokaal door (server-features = no-op).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Admin login (verborgen /admin) ───────────────────────────────────
ADMIN_PASSWORD=
# Lange random string voor HMAC-cookie signing
ADMIN_SECRET=

# ── Discord logging (optioneel) ──────────────────────────────────────
DISCORD_WEBHOOK_URL=
LOG_SECRET=
