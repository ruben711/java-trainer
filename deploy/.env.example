# Kopieer naar .env (naast docker-compose.yml) en vul in.
# Subdomein dat via een A-record naar deze VPS wijst:
PISTON_DOMAIN=piston.jouwsite.be
# Lang, willekeurig geheim. Genereer bv. met: openssl rand -hex 32
# Zet exact ditzelfde token in Vercel als PISTON_AUTH.
PISTON_AUTH=verander-dit-in-een-lange-random-string
